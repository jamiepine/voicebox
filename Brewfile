# macOS only — for Linux setup see: make install-system-linux
# Usage: brew bundle  OR  make install-system

# Python 3.12 — ML packages have the widest compatibility here
brew "python@3.12"

# JavaScript / TypeScript runtime and package manager
brew "bun"

# Rust toolchain manager (installs rustc + cargo)
# NOTE: rustup is preferred over `brew install rust` so you get stable/nightly toolchain switching
brew "rustup"

# Task runner used by the justfile
brew "just"

# Code quality
brew "pre-commit"

# Audio conversion for landing assets (optional but recommended for contributors)
brew "ffmpeg"
brew "webp"
